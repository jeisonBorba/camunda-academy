    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Yes" name="Yes" sourceRef="Gateway_BudgetCodeOutOfDate" targetRef="Activity_0pgqb29">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isUpdateNeeded</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0l974yq" name="Verification ended">
