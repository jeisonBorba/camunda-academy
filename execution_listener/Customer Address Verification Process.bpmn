  <bpmn:process id="Process_CustomerAddressVerification" name="Customer Address Verification Process" isExecutable="true">
    <bpmn:extensionElements />
    <bpmn:sequenceFlow id="Flow_0q51mq3" sourceRef="Activity_VerifyAddress" targetRef="Gateway_BudgetCodeOutOfDate" />
    <bpmn:sequenceFlow id="Flow_1irq6xy" sourceRef="StartEvent_Verification" targetRef="Activity_VerifyAddress" />
