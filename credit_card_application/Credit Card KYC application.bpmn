    <bpmn:textAnnotation id="TextAnnotation_1s78jr2">
      <bpmn:text>Aqui seria um connector do SendGrid para envio de email</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0q5oar6" associationDirection="None" sourceRef="Activity_NotifyCustomerCreditCardApproved" targetRef="TextAnnotation_1s78jr2" />
  </bpmn:process>
