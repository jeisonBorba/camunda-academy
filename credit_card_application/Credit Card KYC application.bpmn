<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="3543595" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="CreditCardKYCApplication" name="Credit Card KYC application" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="Initial" />
    </bpmn:extensionElements>
    <bpmn:businessRuleTask id="Activity_AssessPreliminaryEligibility" name="Assess preliminary eligibility">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_AssessPreliminaryEligibility" resultVariable="eligibilityCheck" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_00k3gzg</bpmn:incoming>
      <bpmn:outgoing>Flow_0qb91zw</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_PreliminaryEligibility" name="Preliminary eligibility OK?" default="Flow_1q2fa8j">
      <bpmn:incoming>Flow_0qb91zw</bpmn:incoming>
      <bpmn:outgoing>Flow_1q2fa8j</bpmn:outgoing>
      <bpmn:outgoing>Flow_0bno19x</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_ReviewKYCRisk" name="Review KYC &#38; risk">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Form_ReviewKYCAndRisk" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0tlfj6o</bpmn:incoming>
      <bpmn:outgoing>Flow_1jdglmz</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0qb91zw" sourceRef="Activity_AssessPreliminaryEligibility" targetRef="Gateway_PreliminaryEligibility" />
    <bpmn:businessRuleTask id="Activity_AssesRisk" name="Assess risk &#38; routing">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_AssessRiskAndRouting" resultVariable="riskCheck" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0c8dxd4</bpmn:incoming>
      <bpmn:outgoing>Flow_0ohqzt3</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="Flow_1q2fa8j" name="no" sourceRef="Gateway_PreliminaryEligibility" targetRef="Activity_NotifyCustomerNotEligible" />
    <bpmn:endEvent id="EndEvent_NotEligible" name="Credit card application ended (not eligible)">
      <bpmn:incoming>Flow_0v6czp3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0v6czp3" sourceRef="Activity_NotifyCustomerNotEligible" targetRef="EndEvent_NotEligible" />
    <bpmn:exclusiveGateway id="Gateway_RoutingDecision" name="Routing decision" default="Flow_Reject">
      <bpmn:incoming>Flow_0ohqzt3</bpmn:incoming>
      <bpmn:outgoing>Flow_0tlfj6o</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_1gtdlfo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0ohqzt3" sourceRef="Activity_AssesRisk" targetRef="Gateway_RoutingDecision" />
    <bpmn:sequenceFlow id="Flow_0tlfj6o" name="Manual review" sourceRef="Gateway_RoutingDecision" targetRef="Activity_ReviewKYCRisk">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskCheck.routingDecision = "MANUAL_REVIEW"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_1plpaig">
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_0zdahle</bpmn:incoming>
      <bpmn:outgoing>Flow_0pz8m2b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_0dxxp14">
      <bpmn:incoming>Flow_19m3shs</bpmn:incoming>
      <bpmn:incoming>Flow_1gtdlfo</bpmn:incoming>
      <bpmn:outgoing>Flow_15pfg0f</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Reject" name="Reject" sourceRef="Gateway_RoutingDecision" targetRef="Gateway_1plpaig" />
    <bpmn:sequenceFlow id="Flow_0pz8m2b" sourceRef="Gateway_1plpaig" targetRef="Activity_NotifyCustomerRejectedRisk" />
    <bpmn:endEvent id="EndEvent_OnboardingEndedRejectedRisk" name="Credit card application ended (risk reject)">
      <bpmn:incoming>Flow_1jx3k1i</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_CustomerOnboarded" name="Credit card approved &#38; onboarded">
      <bpmn:incoming>Flow_05mb0qv</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="Activity_CreateCreditCardAccount" name="Create card account and credit limit (simulated)">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  creditLimit: productRequest.requestedLimit,&#10;  creditCardId: uuid()&#10;}" resultVariable="accountCreationResult" />
        <zeebe:ioMapping>
          <zeebe:output source="=accountCreationResult.creditLimit" target="creditLimit" />
          <zeebe:output source="=accountCreationResult.creditCardId" target="creditCardId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15pfg0f</bpmn:incoming>
      <bpmn:outgoing>Flow_1hyzvc3</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:startEvent id="StartEvent_KYCDocumentReceived" name="Credit card application received">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="Form_NewBankingProduct" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1uwu71m</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0bno19x" name="yes" sourceRef="Gateway_PreliminaryEligibility" targetRef="Activity_FetchRiskScreeningData">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=eligibilityCheck.preliminaryEligibility</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jx3k1i" sourceRef="Activity_NotifyCustomerRejectedRisk" targetRef="EndEvent_OnboardingEndedRejectedRisk" />
    <bpmn:sequenceFlow id="Flow_1uwu71m" sourceRef="StartEvent_KYCDocumentReceived" targetRef="Activity_0l8r227" />
    <bpmn:sequenceFlow id="Flow_1jdglmz" sourceRef="Activity_ReviewKYCRisk" targetRef="Gateway_0exteur" />
    <bpmn:exclusiveGateway id="Gateway_0exteur" name="Manual review decision?">
      <bpmn:incoming>Flow_1jdglmz</bpmn:incoming>
      <bpmn:outgoing>Flow_19m3shs</bpmn:outgoing>
      <bpmn:outgoing>Flow_0zdahle</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_19m3shs" name="Approve" sourceRef="Gateway_0exteur" targetRef="Gateway_0dxxp14">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=manualDecision = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0zdahle" name="Reject" sourceRef="Gateway_0exteur" targetRef="Gateway_1plpaig">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=manualDecision = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1hyzvc3" sourceRef="Activity_CreateCreditCardAccount" targetRef="Activity_NotifyCustomerCreditCardApproved" />
    <bpmn:sequenceFlow id="Flow_00k3gzg" sourceRef="Activity_0l8r227" targetRef="Activity_AssessPreliminaryEligibility" />
    <bpmn:scriptTask id="Activity_0l8r227" name="Normalize KYC data">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  &#34;john&#34;: {&#10;    &#34;email&#34;: &#34;john-doe@example.com&#34;,&#10;    &#34;annualIncome&#34;: &#34;65000&#34;,&#10;    &#34;fullName&#34;: &#34;John Doe&#34;,&#10;    &#34;dateOfBirth&#34;: &#34;1985-07-14&#34;,&#10;    &#34;country&#34;: &#34;Deutschland&#34;,&#10;    &#34;city&#34;: &#34;Lindenfelsheim&#34;,&#10;    &#34;nationalId&#34;: &#34;123456789&#34;,&#10;    &#34;employmentStatus&#34;: &#34;Employed&#34;,&#10;    &#34;countryCode&#34;: &#34;DE&#34;,&#10;    &#34;address&#34;: &#34;Goethestraße 14&#34;,&#10;    &#34;netWorth&#34;: &#34;50000&#34;&#10;  },&#10;  &#34;alex&#34;: {&#10;    &#34;email&#34;: &#34;alexminister@example.com&#34;,&#10;    &#34;annualIncome&#34;: &#34;125000&#34;,&#10;    &#34;fullName&#34;: &#34;Alex Minister&#34;,&#10;    &#34;dateOfBirth&#34;: &#34;1972-03-08&#34;,&#10;    &#34;country&#34;: &#34;Deutschland&#34;,&#10;    &#34;city&#34;: &#34;Neustetten&#34;,&#10;    &#34;nationalId&#34;: &#34;123456789&#34;,&#10;    &#34;employmentStatus&#34;: &#34;Employed&#34;,&#10;    &#34;countryCode&#34;: &#34;DE&#34;,&#10;    &#34;address&#34;: &#34;Friedrich-Schiller-Straße 27&#34;,&#10;    &#34;netWorth&#34;: &#34;750000&#34;&#10;  },&#10;  &#34;emma&#34;: {&#10;    &#34;email&#34;: &#34;emmamuller@example.com&#34;,&#10;    &#34;annualIncome&#34;: &#34;65000&#34;,&#10;    &#34;fullName&#34;: &#34;Emma Müller&#34;,&#10;    &#34;dateOfBirth&#34;: &#34;1990-11-02&#34;,&#10;    &#34;country&#34;: &#34;Deutschland&#34;,&#10;    &#34;city&#34;: &#34;Nordbruck&#34;,&#10;    &#34;nationalId&#34;: &#34;123456789&#34;,&#10;    &#34;employmentStatus&#34;: &#34;Employed&#34;,&#10;    &#34;countryCode&#34;: &#34;DE&#34;,&#10;    &#34;address&#34;: &#34;Am Lindenpark 88&#34;,&#10;    &#34;netWorth&#34;: &#34;50000&#34;&#10;  },&#10;  &#34;mia&#34;: {&#10;    &#34;email&#34;: &#34;mia-roberts@example.com&#34;,&#10;    &#34;annualIncome&#34;: &#34;12000&#34;,&#10;    &#34;fullName&#34;: &#34;Mia Roberts&#34;,&#10;    &#34;dateOfBirth&#34;: &#34;1994-03-22&#34;,&#10;    &#34;country&#34;: &#34;United Kingdom&#34;,&#10;    &#34;city&#34;: &#34;Oakford&#34;,&#10;    &#34;nationalId&#34;: &#34;987654321&#34;,&#10;    &#34;employmentStatus&#34;: &#34;Unemployed&#34;,&#10;    &#34;countryCode&#34;: &#34;GB&#34;,&#10;    &#34;address&#34;: &#34;14 Willow Lane&#34;,&#10;    &#34;netWorth&#34;: &#34;3000&#34;&#10;  },&#10;  &#34;liam&#34;: {&#10;    &#34;email&#34;: &#34;liam-carter@example.com&#34;,&#10;    &#34;annualIncome&#34;: &#34;62000&#34;,&#10;    &#34;fullName&#34;: &#34;Liam Carter&#34;,&#10;    &#34;dateOfBirth&#34;: &#34;1978-09-05&#34;,&#10;    &#34;country&#34;: &#34;Poland&#34;,&#10;    &#34;city&#34;: &#34;Nowowice&#34;,&#10;    &#34;nationalId&#34;: &#34;987654321&#34;,&#10;    &#34;employmentStatus&#34;: &#34;Employed&#34;,&#10;    &#34;countryCode&#34;: &#34;PL&#34;,&#10;    &#34;address&#34;: &#34;ul. Jana Matejki 12&#34;,&#10;    &#34;netWorth&#34;: &#34;35000&#34;    &#10;  }&#10;}" resultVariable="normalizedKycData" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1uwu71m</bpmn:incoming>
      <bpmn:outgoing>Flow_00k3gzg</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:manualTask id="Activity_NotifyCustomerNotEligible" name="Notify applicant: Credit card not eligible">
      <bpmn:incoming>Flow_1q2fa8j</bpmn:incoming>
      <bpmn:outgoing>Flow_0v6czp3</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_1gtdlfo" name="Approve" sourceRef="Gateway_RoutingDecision" targetRef="Gateway_0dxxp14">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskCheck.routingDecision = "AUTO_APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:manualTask id="Activity_NotifyCustomerRejectedRisk" name="Notify applicant: Credit card rejected (risk)">
      <bpmn:incoming>Flow_0pz8m2b</bpmn:incoming>
      <bpmn:outgoing>Flow_1jx3k1i</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="Activity_NotifyCustomerCreditCardApproved" name="Credit card approval email">
      <bpmn:incoming>Flow_1hyzvc3</bpmn:incoming>
      <bpmn:outgoing>Flow_05mb0qv</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:sequenceFlow id="Flow_05mb0qv" sourceRef="Activity_NotifyCustomerCreditCardApproved" targetRef="EndEvent_CustomerOnboarded" />
    <bpmn:sequenceFlow id="Flow_15pfg0f" sourceRef="Gateway_0dxxp14" targetRef="Activity_CreateCreditCardAccount" />
    <bpmn:serviceTask id="Activity_FetchRiskScreeningData" name="Fetch risk &#38; screening data" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="https://academy-dummy-rest-203366991135.europe-west1.run.app/risk-screening" target="url" />
          <zeebe:input source="={&#34;fullName&#34;:normalizedKycData.liam.fullName}" target="queryParameters" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;    &#34;riskAnalysis&#34;: {&#10;        &#34;creditScore&#34; : body.creditScore,&#10;        &#34;probabilityOfDefault12m&#34; : body.probabilityOfDefault12m,&#10;        &#34;pep&#34;: body.pep,&#10;        &#34;sanctionsHit&#34;: body.sanctionsHit,&#10;        &#34;overallRiskLevel&#34;: body.overallRiskLevel&#10;    }&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0bno19x</bpmn:incoming>
      <bpmn:outgoing>Flow_0c8dxd4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0c8dxd4" sourceRef="Activity_FetchRiskScreeningData" targetRef="Activity_AssesRisk" />
    <bpmn:textAnnotation id="TextAnnotation_0bkhrc4">
      <bpmn:text>Modified from send-grid connector do manual task</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0tn049s" associationDirection="None" sourceRef="Activity_NotifyCustomerNotEligible" targetRef="TextAnnotation_0bkhrc4" />
    <bpmn:textAnnotation id="TextAnnotation_19o05me">
      <bpmn:text>Aqui seria um connector do SendGrid para envio de email</bpmn:text>
