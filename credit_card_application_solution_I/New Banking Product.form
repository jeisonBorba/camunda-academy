  "id": "Form_NewBankingProduct",
  "components": [
    {
      "text": "### Request a new banking product\n\n*Choose the product you want, provide your details, and upload your identification and supporting documents to start your request.*",
      "type": "text",
      "layout": {
        "row": "Row_0ilxgw4",
        "columns": null
      },
      "id": "Field_0693sbp"
    },
    {
      "label": "Product",
      "components": [
        {
          "label": "Product type",
          "values": [
            {
              "label": "Credit Card",
              "value": "CREDIT_CARD"
            }
          ],
          "type": "select",
          "layout": {
            "row": "Row_1kgpode",
            "columns": null
          },
          "id": "Field_1xooak4",
          "key": "productType"
        },
        {
          "label": "Card variant",
          "values": [
            {
              "label": "Gold",
              "value": "GOLD"
            }
          ],
          "type": "select",
          "layout": {
            "row": "Row_1kgpode",
            "columns": null
          },
          "id": "Field_1rgyyjt",
          "key": "cardVariant",
          "disabled": false,
          "conditional": {
            "hide": "=not(productRequest.productType = \"CREDIT_CARD\")"
          },
          "defaultValue": "GOLD",
          "readonly": true
        },
        {
          "label": "Requested credit limit",
          "type": "number",
          "layout": {
            "row": "Row_13ajcge",
            "columns": null
          },
          "id": "Field_16ij4za",
          "key": "requestedLimit",
          "defaultValue": 8000,
          "conditional": {
            "hide": "=not(productRequest.productType = \"CREDIT_CARD\")"
          }
        }
      ],
      "showOutline": true,
      "type": "group",
      "layout": {
        "row": "Row_1kun4ub",
        "columns": null
      },
      "id": "Field_0hr6m0i",
      "path": "productRequest"
    },
    {
      "label": "Upload credit card KYC document (ID + proof of income)",
