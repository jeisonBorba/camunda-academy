<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="6a26373" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="Visa-Gold-Credit-Card-KYC-application" name="Visa Gold Credit Card KYC application" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="Visa Gold Credit Card KYC application - no AO (no JSON)" />
    </bpmn:extensionElements>
    <bpmn:serviceTask id="Activity_ExtractKYCData" name="Extract KYC &#38; application data" zeebe:modelerTemplate="idp-unstructured-extraction-connector-5a68eaaf-844c-4e45-8d4d-9ca9f0ba51b0" zeebe:modelerTemplateVersion="4" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:idp-extraction-connector-template:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=kycdoc" target="input.document" />
          <zeebe:input source="= input.extractionType" target="input.extractionType" />
          <zeebe:input source="=[&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the full name of the customer&#34;,&#10;    &#34;name&#34;: &#34;fullName&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the date of birth of the customer&#34;,&#10;    &#34;name&#34;: &#34;dateOfBirth&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the address of the customer&#34;,&#10;    &#34;name&#34;: &#34;address&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the email of the customer&#34;,&#10;    &#34;name&#34;: &#34;email&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the ID No./CR No./Registration No of the customer&#34;,&#10;    &#34;name&#34;: &#34;nationalId&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the Employment Status&#34;,&#10;    &#34;name&#34;: &#34;employmentStatus&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the annual income of the customer&#34;,&#10;    &#34;name&#34;: &#34;annualIncome&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the net worth of the customer&#34;,&#10;    &#34;name&#34;: &#34;netWorth&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the country of the customer&#34;,&#10;    &#34;name&#34;: &#34;country&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;It&#39;s the country code of the customer&#34;,&#10;    &#34;name&#34;: &#34;countryCode&#34;&#10;  }&#10;]" target="input.taxonomyItems" />
          <zeebe:input source="= input.includedFields" target="input.includedFields" />
          <zeebe:input source="= input.renameMappings" target="input.renameMappings" />
          <zeebe:input source="= input.delimiter" target="input.delimiter" />
          <zeebe:input source="={&#10;  &#34;modelId&#34;: &#34;anthropic.claude-sonnet-4-20250514-v1:0&#34;&#10;}" target="input.converseData" />
          <zeebe:input source="aws" target="baseRequest.type" />
          <zeebe:input source="credentials" target="baseRequest.authentication.type" />
          <zeebe:input source="{{secrets.IDP_AWS_ACCESSKEY}}" target="baseRequest.authentication.accessKey" />
          <zeebe:input source="{{secrets.IDP_AWS_SECRETKEY}}" target="baseRequest.authentication.secretKey" />
          <zeebe:input source="{{secrets.IDP_AWS_BUCKET_NAME}}" target="baseRequest.s3BucketName" />
          <zeebe:input source="AWS_TEXTRACT" target="baseRequest.extractionEngineType" />
          <zeebe:input source="{{secrets.IDP_AWS_REGION}}" target="baseRequest.configuration.region" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="2" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connector.IdpExtractionOutBoundTemplate.v1" />
          <zeebe:header key="resultExpression" value="={&#34;normalizedKycData&#34;: extractedFields}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0gjf8z3</bpmn:incoming>
      <bpmn:outgoing>Flow_08c56ur</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Activity_AssessPreliminaryEligibility" name="Assess preliminary eligibility">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="assess-preliminary-eligibility-1533s94" resultVariable="eligibilityCheck" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_08c56ur</bpmn:incoming>
      <bpmn:outgoing>Flow_0qb91zw</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_PreliminaryEligibility" name="Preliminary eligibility OK?" default="Flow_1q2fa8j">
      <bpmn:incoming>Flow_0qb91zw</bpmn:incoming>
      <bpmn:outgoing>Flow_1q2fa8j</bpmn:outgoing>
      <bpmn:outgoing>Flow_0bno19x</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_ReviewKYCRisk" name="Review KYC &#38; risk">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Form_ReviewKYCRisk" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0tlfj6o</bpmn:incoming>
      <bpmn:outgoing>Flow_08zn7dw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0qb91zw" sourceRef="Activity_AssessPreliminaryEligibility" targetRef="Gateway_PreliminaryEligibility" />
    <bpmn:businessRuleTask id="Activity_AssesRisk" name="Assess risk &#38; routing">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="assess-risk-and-routing" resultVariable="riskCheck" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0c8dxd4</bpmn:incoming>
      <bpmn:outgoing>Flow_0ohqzt3</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="Flow_1q2fa8j" name="no" sourceRef="Gateway_PreliminaryEligibility" targetRef="Activity_NotifyCustomerNotEligible" />
    <bpmn:endEvent id="EndEvent_NotEligible" name="Credit card application ended (not eligible)">
      <bpmn:incoming>Flow_0v6czp3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0v6czp3" sourceRef="Activity_NotifyCustomerNotEligible" targetRef="EndEvent_NotEligible" />
    <bpmn:exclusiveGateway id="Gateway_RoutingDecision" name="Routing decision" default="Flow_Reject">
      <bpmn:incoming>Flow_0ohqzt3</bpmn:incoming>
      <bpmn:outgoing>Flow_0tlfj6o</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_AutoApprove</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0ohqzt3" sourceRef="Activity_AssesRisk" targetRef="Gateway_RoutingDecision" />
    <bpmn:sequenceFlow id="Flow_0tlfj6o" name="Manual review" sourceRef="Gateway_RoutingDecision" targetRef="Activity_ReviewKYCRisk">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskCheck.routingDecision = "MANUAL_REVIEW"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_ManualReviewDecision" name="Manual review decision?" default="Flow_ManualReject">
      <bpmn:incoming>Flow_08zn7dw</bpmn:incoming>
      <bpmn:outgoing>Flow_ManualApprove</bpmn:outgoing>
      <bpmn:outgoing>Flow_ManualReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_08zn7dw" sourceRef="Activity_ReviewKYCRisk" targetRef="Gateway_ManualReviewDecision" />
    <bpmn:exclusiveGateway id="Gateway_1plpaig">
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_ManualReject</bpmn:incoming>
      <bpmn:outgoing>Flow_0pz8m2b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_0dxxp14">
      <bpmn:incoming>Flow_AutoApprove</bpmn:incoming>
      <bpmn:incoming>Flow_ManualApprove</bpmn:incoming>
      <bpmn:outgoing>Flow_05u237x</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Reject" name="Reject" sourceRef="Gateway_RoutingDecision" targetRef="Gateway_1plpaig" />
    <bpmn:sequenceFlow id="Flow_AutoApprove" name="Auto approve" sourceRef="Gateway_RoutingDecision" targetRef="Gateway_0dxxp14">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskCheck.routingDecision = "AUTO_APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0pz8m2b" sourceRef="Gateway_1plpaig" targetRef="Activity_NotifyCustomerRejectedRisk" />
    <bpmn:endEvent id="EndEvent_OnboardingEndedRejectedRisk" name="Credit card application ended (risk reject)">
      <bpmn:incoming>Flow_1jx3k1i</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_05u237x" sourceRef="Gateway_0dxxp14" targetRef="Activity_CreateCreditCardAccount" />
    <bpmn:endEvent id="EndEvent_CustomerOnboarded" name="Credit card approved &#38; onboarded">
      <bpmn:incoming>Flow_0m69dvc</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ManualApprove" name="Approve" sourceRef="Gateway_ManualReviewDecision" targetRef="Gateway_0dxxp14">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=manualDecision</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ManualReject" name="Reject" sourceRef="Gateway_ManualReviewDecision" targetRef="Gateway_1plpaig" />
    <bpmn:scriptTask id="Activity_CreateCreditCardAccount" name="Create card account and credit limit (simulated)">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  creditLimit: productRequest.requestedLimit,&#10;  creditCardId: uuid()&#10;}" resultVariable="accountCreationResult" />
        <zeebe:ioMapping>
          <zeebe:output source="=accountCreationResult.creditLimit" target="creditLimit" />
          <zeebe:output source="=accountCreationResult.creditCardId" target="creditCardId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_05u237x</bpmn:incoming>
    </bpmn:scriptTask>
    <bpmn:startEvent id="StartEvent_KYCDocumentReceived" name="Credit card application received">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="new-banking-product" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0gjf8z3</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0gjf8z3" sourceRef="StartEvent_KYCDocumentReceived" targetRef="Activity_ExtractKYCData" />
    <bpmn:serviceTask id="Activity_FetchRiskScreeningData" name="Fetch risk &#38; screening data" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=false" target="ignoreNullValues" />
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="https://academy-dummy-rest-203366991135.europe-west1.run.app/risk-screening" target="url" />
          <zeebe:input source="={&#34;fullName&#34;:normalizedKycData.fullName}" target="queryParameters" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  &#34;riskAnalysis&#34;:{&#10;  &#34;pep&#34;:body.pep,&#10;  &#34;sanctionsHit&#34;: body.sanctionsHit,&#10;  &#34;creditScore&#34;: body.creditScore,&#10;  &#34;probabilityOfDefault12m&#34;: body.probabilityOfDefault12m,&#10;  &#34;overallRiskLevel&#34;:body.overallRiskLevel,&#10;  &#34;overallRiskReason&#34;: body.overallRiskReason,&#10;  &#34;riskFactors&#34;: body.riskFactors&#10;}&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0bno19x</bpmn:incoming>
      <bpmn:outgoing>Flow_0c8dxd4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_NotifyCustomerNotEligible" name="Notify applicant: Credit card not eligible" zeebe:modelerTemplate="io.camunda.connectors.SendGrid.v2" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendgrid:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SENDGRID_KEY}}" target="apiKey" />
          <zeebe:input source="Credit card application" target="from.name" />
          <zeebe:input source="demo@camunda.com" target="from.email" />
          <zeebe:input source="=normalizedKycData.fullName" target="to.name" />
          <zeebe:input target="to.email" />
          <zeebe:input source="mail" target="unMappedFieldNotUseInModel.mailType" />
          <zeebe:input source="Credit card application: not eligible" target="content.subject" />
          <zeebe:input source="text/plain" target="content.type" />
          <zeebe:input source="=&#34;Hello &#34; + normalizedKycData.fullName + &#34;,\n\nYour credit card application is not eligible due to &#34; + elegibilityCheck.reasonCode + &#34;.\n\nThank you for choosing us.\n\nBest regards,\nCredit card team&#34;" target="content.value" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.SendGrid.v2" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1q2fa8j</bpmn:incoming>
      <bpmn:outgoing>Flow_0v6czp3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_08c56ur" sourceRef="Activity_ExtractKYCData" targetRef="Activity_AssessPreliminaryEligibility" />
    <bpmn:sequenceFlow id="Flow_0bno19x" name="yes" sourceRef="Gateway_PreliminaryEligibility" targetRef="Activity_FetchRiskScreeningData">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=eligibilityCheck.preliminaryEligibility</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_NotifyCustomerRejectedRisk" name="Notify applicant: Credit card rejected (risk)" zeebe:modelerTemplate="io.camunda.connectors.SendGrid.v2" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendgrid:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SENDGRID_KEY}}" target="apiKey" />
          <zeebe:input source="Credit card application" target="from.name" />
          <zeebe:input source="demo@camunda.com" target="from.email" />
          <zeebe:input source="=normalizedKycData.fullName" target="to.name" />
          <zeebe:input target="to.email" />
          <zeebe:input source="mail" target="unMappedFieldNotUseInModel.mailType" />
          <zeebe:input source="Credit card application: REJECTED after risk assessment" target="content.subject" />
          <zeebe:input source="text/plain" target="content.type" />
          <zeebe:input source="=&#34;Hello &#34; + normalizedKycData.fullName + &#34;,\n\nYour credit card application was rejected following our risk and compliance assessment.\n\nThank you for choosing us.\n\nBest regards,\nCredit card team&#34;" target="content.value" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.SendGrid.v2" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0pz8m2b</bpmn:incoming>
      <bpmn:outgoing>Flow_1jx3k1i</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1jx3k1i" sourceRef="Activity_NotifyCustomerRejectedRisk" targetRef="EndEvent_OnboardingEndedRejectedRisk" />
    <bpmn:sequenceFlow id="Flow_0625ybx" sourceRef="Activity_CreateCreditCardAccount" targetRef="Activity_1c2ku80" />
    <bpmn:sequenceFlow id="Flow_0c8dxd4" sourceRef="Activity_FetchRiskScreeningData" targetRef="Activity_AssesRisk" />
    <bpmn:serviceTask id="Activity_1c2ku80" name="Send credit card approval email" zeebe:modelerTemplate="io.camunda.connectors.SendGrid.v2" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendgrid:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SENDGRID_KEY}}" target="apiKey" />
          <zeebe:input source="Credit card application" target="from.name" />
          <zeebe:input source="demo@camunda.com" target="from.email" />
          <zeebe:input source="=normalizedKycData.fullName" target="to.name" />
          <zeebe:input target="to.email" />
          <zeebe:input source="mail" target="unMappedFieldNotUseInModel.mailType" />
          <zeebe:input source="Your credit card has been approved" target="content.subject" />
          <zeebe:input source="text/plain" target="content.type" />
          <zeebe:input source="=&#34;Hello &#34; + normalizedKycData.fullName + &#34;,\n\nWe are pleased to inform you that your product request &#34; + creditCardId + &#34; has been approved with a credit limit of: &#34; + string(creditLimit) + &#34;.\n\nYou will receive your card shortly. Once it arrives, please follow the instructions to activate it and set your PIN in our online banking or mobile app.\n\nThank you for choosing us.\n\nBest regards,\nCredit card team&#34;" target="content.value" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.SendGrid.v2" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0625ybx</bpmn:incoming>
      <bpmn:outgoing>Flow_0m69dvc</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0m69dvc" sourceRef="Activity_1c2ku80" targetRef="EndEvent_CustomerOnboarded" />
  </bpmn:process>
  <bpmn:message id="Message_2o51p0f" name="msg_kyc-document" />
