      <bpmn:extensionElements>
        <zeebe:formDefinition formId="review-loan-request-1woqd8d" />
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1fksc1t</bpmn:incoming>
      <bpmn:outgoing>Flow_1a8zg8l</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_0nm1kzm" name="Approved?">
      <bpmn:incoming>Flow_1a8zg8l</bpmn:incoming>
      <bpmn:outgoing>Flow_1js0lvm</bpmn:outgoing>
      <bpmn:outgoing>Flow_1b77qhi</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1a8zg8l" sourceRef="Activity_1mniuc6" targetRef="Gateway_0nm1kzm" />
    <bpmn:sequenceFlow id="Flow_1js0lvm" name="yes" sourceRef="Gateway_0nm1kzm" targetRef="Activity_1ifof0v">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=loanAccepted</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sendTask id="Activity_1ifof0v" name="send confirmation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="acceptLoan" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1js0lvm</bpmn:incoming>
      <bpmn:outgoing>Flow_03s0rkd</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sendTask id="Activity_0oh8vhy" name="send rejection">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="rejectLoan" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1b77qhi</bpmn:incoming>
      <bpmn:outgoing>Flow_1m4pn4d</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_1b77qhi" name="no" sourceRef="Gateway_0nm1kzm" targetRef="Activity_0oh8vhy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=not(loanAccepted)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0r8ioga" name="Loan accepted">
      <bpmn:incoming>Flow_03s0rkd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_03s0rkd" sourceRef="Activity_1ifof0v" targetRef="Event_0r8ioga" />
    <bpmn:endEvent id="Event_1mglxmi" name="Loan rejected">
      <bpmn:incoming>Flow_1m4pn4d</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1m4pn4d" sourceRef="Activity_0oh8vhy" targetRef="Event_1mglxmi" />
  </bpmn:process>
