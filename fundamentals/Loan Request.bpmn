  <bpmn:process id="Process_1hnk6le" name="Play Overview" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Loan request received">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="camundaModeler:exampleOutputJson" value="{&#34;loan&#34;:15000, &#34;reason&#34;:&#34;I want to buy a new car&#34;, &#34;durationInMonth&#34;: 36}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_16z11ys</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_16z11ys" sourceRef="StartEvent_1" targetRef="Activity_13mige0" />
    <bpmn:scriptTask id="Activity_13mige0" name="calculate monthly rate">
      <bpmn:extensionElements>
        <zeebe:script expression="=loan/durationInMonth" resultVariable="monthlyRate" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_16z11ys</bpmn:incoming>
      <bpmn:outgoing>Flow_1fksc1t</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1fksc1t" sourceRef="Activity_13mige0" targetRef="Activity_1mniuc6" />
