      <bpmndi:BPMNShape id="Event_1bqaxf3_di" bpmnElement="Event_1bqaxf3">
        <dc:Bounds x="1422" y="463" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1407" y="506" width="67" height="27" />
