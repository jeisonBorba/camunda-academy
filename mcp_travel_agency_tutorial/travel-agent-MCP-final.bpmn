<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="882a44a" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="Process_mekl8ld" name="Travel Agent" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="v2" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="StartEvent_1" name="Request sent">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="request-sent-0lvu2vq" />
        <zeebe:ioMapping>
          <zeebe:output source="=&#34;notYet&#34;" target="customerSatisfied" />
          <zeebe:output source="=append([], request)" target="requestList" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_15q9l0z</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="Activity_0znosnu" name="Travel agency" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-20250514-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=10000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.2" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.topP" />
          <zeebe:input source="=&#34;You are **Travel Agent**, a helpful travel chat agent that can handle a wide variety of travel requests using your own domain knowledge **and** any tools explicitly provided to you at runtime.&#10;&#10;## Persona and Objective&#10;- You act as a professional, friendly **human travel agent**.&#10;- Your primary objective is to **help users plan and organize their trips end-to-end** (flights, hotels, transport, activities) while respecting their preferences and constraints (budget, timing, comfort, special needs).&#10;- You must be **clear, pragmatic, and safety-conscious**: avoid risky itineraries, highlight constraints (visas, connection times, seasonality), and surface trade-offs when relevant.&#10;&#10;## Core Behavior&#10;&#10;**Tool Usage**&#10;- If tools are provided, you MUST prefer them instead of guessing an answer.&#10;- You can call the same tool multiple times with different input values.&#10;- Never guess or invent tools that were not explicitly configured.&#10;- If no tool matches the request, try to generate an answer using your knowledge.&#10;- If you cannot find a good answer, clearly state why you&#39;re unable to help.&#10;&#10;**Date and Time Handling**&#10;- ALWAYS check the current system date and time before processing any date‑related requests.&#10;- When users mention relative dates (for example: **&#39;today&#39;**, **&#39;tomorrow&#39;**, **&#39;next Friday&#39;**, **&#39;in 3 days&#39;**, **&#39;this weekend&#39;**), calculate the actual calendar date based on the current system time.&#10;- When you use a calculated date, **echo it back explicitly** to the user (for example:  &#10;  &#62; “By ‘next Friday’ I understand **Friday, 14 February 2026** in your timezone. If that’s not correct, please tell me.”)&#10;- When you are requested to find flights, use **IATA codes** for the airports (for example: CDG for Paris Charles de Gaulle).&#10;&#10;**Output Formatting**&#10;- Use **markdown syntax** for all responses.&#10;- Use **lists and tables** to improve readability and layout.&#10;- Use short section headers when helpful (for example: **Options**, **Summary**, **Next steps**).&#10;&#10;**Interaction and Safety**&#10;- If important information is missing (dates, origin/destination, passenger count, budget, flexibility), ask **targeted clarifying questions** before proceeding.&#10;- Never commit to booking or purchasing anything unless the user clearly confirms the exact itinerary and conditions.&#10;- If tools or data indicate problems (sold out, invalid dates, impossible connections), explain the issue briefly and propose reasonable alternatives.&#10;&#10;**Reasoning Visibility**&#10;- Reveal **no** additional private reasoning, internal thoughts, or hidden analysis steps.&#10;- Only include information in your response that is directly useful to the user.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=request" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=30" target="data.memory.contextWindowSize" />
          <zeebe:input source="=30" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_11z81ya</bpmn:incoming>
      <bpmn:outgoing>Flow_1ffitql</bpmn:outgoing>
      <bpmn:serviceTask id="call-travel-agency" name="Call travel agency" zeebe:modelerTemplate="io.camunda.connectors.agenticai.mcp.remoteclient.v0" zeebe:modelerTemplateVersion="2" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Search travel options: hotel, flights, accomodations</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda.agenticai:mcpremoteclient:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="http" target="data.transport.type" />
            <zeebe:input source="{{secrets.TRAVEL_AGENCY_URL}}/mcp" target="data.transport.http.url" />
            <zeebe:input source="bearer" target="data.transport.http.authentication.type" />
            <zeebe:input source="{{secrets.TRAVEL_AGENCY_TOKEN}}" target="data.transport.http.authentication.token" />
            <zeebe:input source="=false" target="data.options.clientCache" />
            <zeebe:input source="aiAgentTool" target="data.connectorMode.type" />
            <zeebe:input source="=toolCall.method" target="data.connectorMode.toolOperation.method" />
            <zeebe:input source="=toolCall.params" target="data.connectorMode.toolOperation.params" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="2" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.mcp.remoteclient.v0" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
          <zeebe:properties>
            <zeebe:property name="io.camunda.agenticai.gateway.type" value="mcpClient" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1bjc40f</bpmn:incoming>
        <bpmn:incoming>Flow_14ckbp2</bpmn:incoming>
      </bpmn:serviceTask>
      <bpmn:userTask id="human_answer_to_customer" name="Answer customer">
        <bpmn:documentation>Use this tool when it's better to involve a human</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="answer-to-customer-1iw88tu" />
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:intermediateThrowEvent id="Event_1m8coe0" name="Agency requested">
        <bpmn:extensionElements>
          <zeebe:properties>
            <zeebe:property name="io.camunda.agenticai.gateway.type" value="mcpClient" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_1gcxzmx</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:exclusiveGateway id="Gateway_116uudr" name="Needs confirmation?" default="Flow_0557fcz">
        <bpmn:incoming>Flow_1gcxzmx</bpmn:incoming>
        <bpmn:outgoing>Flow_1bjc40f</bpmn:outgoing>
        <bpmn:outgoing>Flow_0557fcz</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_1gcxzmx" sourceRef="Event_1m8coe0" targetRef="Gateway_116uudr" />
      <bpmn:sequenceFlow id="Flow_1bjc40f" name="No" sourceRef="Gateway_116uudr" targetRef="call-travel-agency">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=toolCall.method = "tools/list" or list contains([
    "search_flights",
    "search_accommodation",
    "search_experiences",
    "get_today_date"
  ], toolCall.params.name) </bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_11g8kvd" sourceRef="Activity_1nixwpq" targetRef="Gateway_1x0xq7k" />
      <bpmn:intermediateThrowEvent id="Event_1t0t1ii" name="Booking not allowed">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#34;isError&#34;: true, &#34;content&#34;: [{&#34;type&#34;: &#34;text&#34;, &#34;text&#34;: &#34;Booking was not allowed by the Travel agency&#34;}]}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0g1c6zx</bpmn:incoming>
      </bpmn:intermediateThrowEvent>
      <bpmn:exclusiveGateway id="Gateway_1x0xq7k" name="Validated?" default="Flow_0g1c6zx">
        <bpmn:incoming>Flow_11g8kvd</bpmn:incoming>
        <bpmn:outgoing>Flow_14ckbp2</bpmn:outgoing>
        <bpmn:outgoing>Flow_0g1c6zx</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_14ckbp2" name="Yes" sourceRef="Gateway_1x0xq7k" targetRef="call-travel-agency">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=bookingValidated</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_0g1c6zx" name="No" sourceRef="Gateway_1x0xq7k" targetRef="Event_1t0t1ii" />
      <bpmn:sequenceFlow id="Flow_0557fcz" name="Yes" sourceRef="Gateway_116uudr" targetRef="Activity_1nixwpq" />
      <bpmn:userTask id="Activity_1nixwpq" name="Validate booking">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="Form_booking_validation3" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0557fcz</bpmn:incoming>
        <bpmn:outgoing>Flow_11g8kvd</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="getGeoCoordinatesForWeatherForecasting" name="Get geo coordinates" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Get geo coordinates of a location for weather forecasting</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://geocoding-api.open-meteo.com/v1/search" target="url" />
            <zeebe:input source="={ &#10;    name: fromAi(toolCall.location, &#34;the city for weather lookup&#34;),&#10;    count: 1,&#10;    language:&#34;en&#34;&#10;}" target="queryParameters" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:input source="=false" target="ignoreNullValues" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={&#10;  geoCoordinates:{&#10;  latitude: body.results[1].latitude,&#10;  longitude: body.results[1].longitude&#10;  }&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:outgoing>Flow_0m3jpqm</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Activity_06mqg3a" name="Check weather" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Provide weather information of a specific location</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://api.open-meteo.com/v1/forecast" target="url" />
            <zeebe:input source="={ &#10;    latitude: geoCoordinates.latitude,&#10;    longitude: geoCoordinates.longitude,&#10;    current:&#34;temperature_2m,relative_humidity_2m,apparent_temperature,pressure_msl,wind_speed_10m&#34;,&#10;daily:&#34;weather_code,temperature_2m_max,temperature_2m_min&#34;&#10;}" target="queryParameters" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:input source="=false" target="ignoreNullValues" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="resultExpression" value="={&#10;  temperature: response.current.temperature_2m&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0m3jpqm</bpmn:incoming>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_0m3jpqm" sourceRef="getGeoCoordinatesForWeatherForecasting" targetRef="Activity_06mqg3a" />
      <bpmn:association id="Association_1q0mzk0" associationDirection="None" sourceRef="human_answer_to_customer" targetRef="TextAnnotation_0b1edq6" />
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_15q9l0z" sourceRef="StartEvent_1" targetRef="Gateway_122krqy" />
    <bpmn:exclusiveGateway id="Gateway_1fn53th" name="Customer satisfied?">
      <bpmn:incoming>Flow_02h8qjr</bpmn:incoming>
      <bpmn:outgoing>Flow_05vx9am</bpmn:outgoing>
      <bpmn:outgoing>Flow_1rwnpyt</bpmn:outgoing>
      <bpmn:outgoing>Flow_1acs9t0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_05vx9am" name="Yes" sourceRef="Gateway_1fn53th" targetRef="Activity_0thpytm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=customerSatisfied="yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_151wftj" name="Customer satisfied">
      <bpmn:incoming>Flow_05h4nzp</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1ffitql" sourceRef="Activity_0znosnu" targetRef="Activity_1e2fb7a" />
    <bpmn:endEvent id="Event_1bqaxf3" name="Customer not satisfied">
      <bpmn:incoming>Flow_0pe9w0s</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_122krqy">
      <bpmn:incoming>Flow_15q9l0z</bpmn:incoming>
      <bpmn:incoming>Flow_1rwnpyt</bpmn:incoming>
      <bpmn:outgoing>Flow_11z81ya</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_11z81ya" sourceRef="Gateway_122krqy" targetRef="Activity_0znosnu" />
    <bpmn:sequenceFlow id="Flow_1rwnpyt" name="Not yet" sourceRef="Gateway_1fn53th" targetRef="Gateway_122krqy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=customerSatisfied="notYet"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_1e2fb7a" name="Ask follow up question">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="ask-other-question-10704nw" />
        <zeebe:ioMapping>
          <zeebe:input source="=agent.responseText" target="responseText" />
          <zeebe:input target="request" />
          <zeebe:output source="=append(requestList, request)" target="requestList" />
          <zeebe:output source="=request" target="request" />
          <zeebe:output source="=customerSatisfied" target="customerSatisfied" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ffitql</bpmn:incoming>
      <bpmn:outgoing>Flow_02h8qjr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_02h8qjr" sourceRef="Activity_1e2fb7a" targetRef="Gateway_1fn53th" />
    <bpmn:sequenceFlow id="Flow_1acs9t0" name="No" sourceRef="Gateway_1fn53th" targetRef="Activity_0d6cf0g">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=customerSatisfied="no"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:task id="Activity_0thpytm" name="Ask for 5‑star review">
      <bpmn:incoming>Flow_05vx9am</bpmn:incoming>
      <bpmn:outgoing>Flow_05h4nzp</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_05h4nzp" sourceRef="Activity_0thpytm" targetRef="Event_151wftj" />
    <bpmn:task id="Activity_0d6cf0g" name="Give voucher">
      <bpmn:incoming>Flow_1acs9t0</bpmn:incoming>
      <bpmn:outgoing>Flow_0pe9w0s</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_0pe9w0s" sourceRef="Activity_0d6cf0g" targetRef="Event_1bqaxf3" />
    <bpmn:textAnnotation id="TextAnnotation_1nae8cq">
      <bpmn:text>Customer read the agent answer, and can follow-up or share feedback about the service</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0b1edq6">
      <bpmn:text>Fallback to human</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1aoqkt3" associationDirection="None" sourceRef="Activity_1e2fb7a" targetRef="TextAnnotation_1nae8cq" />
    <bpmn:textAnnotation id="TextAnnotation_02q7caw">
      <bpmn:text>Search / book for flights, hotels, experiences</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0um8kb4">
      <bpmn:text>Offer some discount on next purchases</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1j4jhzx" associationDirection="None" sourceRef="Activity_0d6cf0g" targetRef="TextAnnotation_0um8kb4" />
    <bpmn:association id="Association_0o2nvnv" associationDirection="None" sourceRef="call-travel-agency" targetRef="TextAnnotation_02q7caw" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_mekl8ld">
